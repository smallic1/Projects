import matplotlib.pyplot as plt
import numpy as np

plt.title("Breakdown of 5K Results among Male and Female runners analyzed", fontweight="bold")
plt.xlabel("Age group")
plt.ylabel("# of Analyzed finishes")

xpoints = np.array(["10-14", "15-18", "19-22", "23-29", "30-39", "40-49", "50-59", "60-69", "70-79"])
y1points = np.array([74855, 40238, 66027, 200945, 269245, 237260, 160263, 75947, 16452])
y2points = np.array([80534, 41008, 49943, 143017, 202578, 169039, 120255, 66201, 20454])

x = np.arange(len(xpoints)) 
width = 0.35 

plt.bar(x - width/2, y1points, width, color="steelblue", label="Female test-takers")
plt.bar(x + width/2, y2points, width, color="crimson", label="Male test-takers")

plt.xticks(x, xpoints)

plt.legend(loc='upper left', title='Legend')
plt.figtext(0.515, 0.02, "Source: https://run.outsideonline.com/road/road-racing/whats-a-good-5k-time-heres-what-the-latest-data-says/", ha="center", fontsize=10, color="black")
plt.show()
