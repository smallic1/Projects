import plotly.graph_objects as go

categories = ["Car, Truck, or Van - drove alone", "Car, Truck, or Van - carpooled", "Public Transportation", "Walked", "Taxi or ride-hailing services, motorcycle, bicycle, or other means", "Worked from home"]
speak_english_very_well = [1103753, 200612, 19509, 21299, 35325, 242441]
speak_english_less_than_very_well = [877075, 241201, 36865, 23083, 46572, 106070]
labels_very_well = [f"{category}: {value:,} speak English very well" for category, value in zip(categories, speak_english_very_well)]
labels_less_than_very_well = [f"{category}: {value:,} speak English less than very well" for category, value in zip(categories, speak_english_less_than_very_well)]

trace1 = go.Bar(x=categories, y=speak_english_very_well, name="Speak English very well", marker_color="blue", customdata=labels_very_well, hovertemplate="%{customdata}<extra></extra>")
trace2 = go.Bar(x=categories, y=speak_english_less_than_very_well, name="Speak English less than very well", marker_color="red", customdata=labels_less_than_very_well, hovertemplate="%{customdata}<extra></extra>")
fig = go.Figure(data=[trace1, trace2])

barmode = "group"

fig.update_layout(barmode="group", xaxis_title="English-language speaking ability", yaxis_title="Number of surveyed people", title="Means of Transportation to Work by Language Spoken at Home and Ability to Speak English for Workplace Geography - State of Florida, among Spanish-speakers only (2024, ACS)")
fig.add_annotation(text="Source: https://data.census.gov/table/ACSDT1Y2024.B08513?t=Language+Spoken+at+Home&g=010XX00US$0400000", xref="paper", yref="paper", x=-0.05, y=-0.3, showarrow=False)

fig.show()

